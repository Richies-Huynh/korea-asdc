# ---------------------------------------------------------------------------
# Firebase Web SDK (client)
# Firebase console > Project settings > General > Your apps > SDK setup
# ---------------------------------------------------------------------------
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ---------------------------------------------------------------------------
# Firebase Admin SDK (server)
# Firebase console > Project settings > Service accounts > Generate new private key
# Paste the private key as a single line with literal \n for newlines, in quotes.
# ---------------------------------------------------------------------------
FIREBASE_ADMIN_PROJECT_ID=
FIREBASE_ADMIN_CLIENT_EMAIL=
FIREBASE_ADMIN_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"

# ---------------------------------------------------------------------------
# Resend (email alerts) — https://resend.com/api-keys
# ---------------------------------------------------------------------------
RESEND_API_KEY=
# Verified sender, e.g. Fire Watch <alerts@yourdomain.com>
FIRE_ALERT_FROM=
# Recipient for fire alerts (your on-call contact or authority mailbox)
FIRE_ALERT_RECIPIENT=

# ---------------------------------------------------------------------------
# Alerting
# ---------------------------------------------------------------------------
# Minimum seconds between alert emails per monitor (default 300)
FIRE_ALERT_COOLDOWN_SECONDS=300

# ---------------------------------------------------------------------------
# Anthropic (fire prevention scan hazard analysis) — https://console.anthropic.com
# ---------------------------------------------------------------------------
ANTHROPIC_API_KEY=
